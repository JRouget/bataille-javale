<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.geometry.Insets?>

<?import java.net.URL?>
<HBox alignment="CENTER" spacing="80.0" styleClass="main-container"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="school.coda.joshua_hugo.bataillejavale.ui.BatailleController">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <GridPane fx:id="grilleJoueur" alignment="CENTER" styleClass="grid-tactique" />
    <GridPane fx:id="grilleRadar" alignment="CENTER" styleClass="grid-tactique" />

</HBox>