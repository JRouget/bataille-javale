<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import java.net.URL?>

<VBox alignment="CENTER" spacing="50.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="school.coda.joshua_hugo.bataillejavale.ui.accueil_controller"
      styleClass="main-container">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <VBox alignment="CENTER" spacing="10.0">
        <Label text="BATAILLE" styleClass="titre-accent" />
        <Label text="NAVALE" styleClass="titre-principal" />
        <Region styleClass="separator-honneur" />
    </VBox>

    <Button text="LANCER L'OPÉRATION"
            onAction="#onNouvellePartieClick"
            styleClass="button-command" />

    <VBox alignment="CENTER" spacing="5.0" styleClass="footer">
        <Label text="ÉTAT-MAJOR" styleClass="footer-label" />
        <Label text="JOSHUA • HUGO • FLORIAN" styleClass="footer-names" />
    </VBox>

</VBox>